rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /user_portfolios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /market_radar/{document=**} {
      allow read: if true;
      allow write: if request.auth != null; // Restrict writes to authenticated users (e.g., the refresh script)
    }

    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 4, 8);
    }
  }
}
