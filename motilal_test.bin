    function val123Search() {
        var searchText = document.getElementById("txtSearch");
        if (searchText.value.trim() == "" || searchText.value.trim() == "Search") {
            alert("Please Enter Text To Search");
            searchText.focus();
            return false;
        }
        else {

            window.location = "/SiteSearch/" + searchText.value;
            return false;
        }
        return true;

    }
    function val123Mob() {
        var searchText = document.getElementById("txtSearchMob");
        if (searchText.value.trim() == "" || searchText.value.trim() == "Search") {
            alert("Please Enter Text To Search");
            searchText.focus();
            return false;
        }
        else {

            window.location = "/SiteSearch/" + searchText.value;
            return false;
        }
        return true;

    }
    function isAlphaChecktop(evt) {
        if (document.getElementById("txtSearch").value.length > 0) {

            var k = (evt.which) ? evt.which : evt.keyCode;

            return ((k > 32 && k < 46) || (k > 46 && k < 65) || (k > 90 && k < 97) || (k == 46) || (k == 123 || (k == 125)) || (k == 126)) ? false : true;

        }
        else {
            var k = (evt.which) ? evt.which : evt.keyCode;

            return ((k > 32 && k < 46) || (k > 46 && k < 65) || (k > 90 && k < 97) || (k == 32) || (k == 46) || (k == 123 || (k == 125)) || (k == 126)) ? false : true;

        }
    }
    function vanish() {
        var k = (evt.which) ? evt.which : evt.keyCode;
        alert(k);

    }

